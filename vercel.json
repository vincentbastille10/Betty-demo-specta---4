{
  "version": 2,
  "builds": [
    { "src": "api/index.py",  "use": "@vercel/python" },
    { "src": "public/**",     "use": "@vercel/static" },
    { "src": "static/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",   "dest": "/api/index.py" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/chat",        "dest": "/public/index.html" },
    { "src": "/(.*)",        "dest": "/public/$1" }
  ]
}
